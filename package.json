{
  "devDependencies": {
    "@types/jquery": "^3.5.6",
    "@types/lz-string": "^1.3.32",
    "@types/react": "^16.14.69",
    "@types/react-dom": "^16.9.25",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "lz-string": "^1.4.4",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.0",
    "sass": "^1.99.0",
    "sass-loader": "^13.3.3",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.23.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.8.3",
    "webpack": "^5.23.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0"
  },
  "name": "pull-requests-filtered",
  "private": true,
  "version": "0.6.0",
  "scripts": {
    "clean": "rimraf ./dist",
    "compile": "npm run clean && webpack --mode production",
    "compile:dev": "npm run clean && webpack --mode development",
    "build": "npm run compile",
    "build:dev": "npm run compile:dev && npm run postbuild",
    "debug": "webpack-dev-server --mode development",
    "postbuild": "npm run package-extension",
    "package-extension": "tfx extension create --rev-version --manifests vss-extension.json --overrides-file configs/dev.json && tfx extension create --manifests vss-extension.json --overrides-file configs/release.json",
    "publish-extension": "tfx extension publish --rev-version --manifests vss-extension.json --overrides-file configs/release.json"
  },
  "dependencies": {
    "azure-devops-extension-api": "^1.157.0",
    "azure-devops-extension-sdk": "^2.0.11",
    "azure-devops-ui": "^2.167.17",
    "azure-devops-ui-datepicker": "^2.167.17",
    "react": "^16.8.1",
    "react-dom": "^16.8.1",
    "tslib": "^2.3.1"
  }
}
